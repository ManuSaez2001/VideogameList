{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "IGDBRateLimiting": {
        "MaxRequestsPerSecond": 4,
        "RetryMaxAttempts": 3,
        "RetryBackoffMs": 1000,
        "SearchCacheTtlMinutes": 30
    }
}
